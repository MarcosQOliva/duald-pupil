labs(x="accuracy decision 1",
y="accuracy decision 2")
?binom.test
heads <- rbinom(1, size = 100, prob = .5)
heads
# is accuracy significantly higher in decision 2?
prop.test(d$accuracy[d$decision==1], d$accuracy[d$decision==2])
# is accuracy significantly higher in decision 2?
prop.test(sum(d$accuracy[d$decision==1]),
sum(d$accuracy[d$decision==2]),
n=400)
smokers  <- c( 83, 90, 129, 70 )
patients <- c( 86, 93, 136, 82 )
prop.test(smokers, patients)
sum(d$accuracy[d$decision==2])
sum(d$accuracy[d$decision==1])
# is accuracy significantly higher in decision 2?
prop.test(sum(d$accuracy[d$decision==1]),
sum(d$accuracy[d$decision==2]))
# is accuracy significantly higher in decision 2?
prop.test(c(sum(d$accuracy[d$decision==1]), sum(d$accuracy[d$decision==2])),
c(400, 400))
# is accuracy significantly higher in decision 2?
prop.test(c(sum(d$accuracy[d$decision==1]), sum(d$accuracy[d$decision==2])),
alternative = "greater",
c(400, 400))
# is accuracy significantly higher in decision 2?
prop.test(c(sum(d$accuracy[d$decision==1]), sum(d$accuracy[d$decision==2])),
alternative = "less",
c(400, 400))
str(d)
# estimate sensory noise based only on decision 1
d$LR <- log(d$n_right) - log(d$n_left)
d$LR
str(d)
m0 <- glm(response ~ LR, d[d$decision==1,], family=binomial("probit"))
eta <- 1/coef(m0)["s1"]
eta
m0
summary(m0)
eta <- 1/coef(m0)["LR"]
eta
eta * 2
d$discriminability <- abs(d$LR)/eta
d$discriminability
m0 <- glm(accuracy ~ I(decision-1), d, family=binomial("logit"))
summary(m0)
# (optional test, not particularly meaningful at individual level)
prop.test(c(sum(d$accuracy[d$decision==1]), sum(d$accuracy[d$decision==2])),
alternative = "less",
c(400, 400))
d_ag <- d %>%
mutate(difficulty_bin = cut_interval(discriminability, 5)) %>%
group_by(difficulty_bin, decision) %>%
summarise(discriminability = mean(discriminability),
accuracy_se = mlisi::binomSEM(accuracy),
accuracy=mean(accuracy))
d_ag
?geom_smooth
# plot accuracy as a function of discriminability
d_ag <- d %>%
mutate(difficulty_bin = cut_interval(discriminability, 5)) %>%
group_by(difficulty_bin, decision) %>%
summarise(discriminability = mean(discriminability),
se = mlisi::binomSEM(accuracy),
accuracy=mean(accuracy)) %>%
ggplot(aes(x=discriminability, y=accuracy,
group = decision, color=decision)) %>%
geom_point()+
geom_errorbar(aes(ymin=accuracy-se, ymax=accuracy+se), width=0)+
geom_smooth(data=d, method = "glm",
method.args=list(family=binomial(link="probit")))
