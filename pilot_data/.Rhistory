dg <- read_delim("ML01_range_gaze_gaze_samples.tsv")
str(dg)
# remove practice
dg <- dg %>%
filter(phase != "practice_intro" )
unique(dg$event_label)
unique(dg$phase)
unique(dg$phase)
unique(dg$event_label)
